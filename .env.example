# ═══════════════════════════════════════════════════════════════
# AI API Keys
# ═══════════════════════════════════════════════════════════════

# Groq API (Ultra-fast AI inference)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API
# Get yours at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral AI API
# Get yours at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# HuggingFace Token (for image generation fallback)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ═══════════════════════════════════════════════════════════════
# Cloudflare (Optional - for AI image generation)
# ═══════════════════════════════════════════════════════════════

# Cloudflare API Key
CLOUDFLARE_API_KEY=your_cloudflare_api_key

# Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID=your_account_id

# ═══════════════════════════════════════════════════════════════
# LemonSqueezy Payment Integration
# ═══════════════════════════════════════════════════════════════

# LemonSqueezy API Key
# Get yours at: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key

# Your LemonSqueezy Store ID
LEMONSQUEEZY_STORE_ID=your_store_id

# Webhook Secret (for verifying webhooks)
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# ═══════════════════════════════════════════════════════════════
# Optional: Analytics & Monitoring
# ═══════════════════════════════════════════════════════════════

# Google Analytics (optional)
GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN (for error tracking)
SENTRY_DSN=your_sentry_dsn
