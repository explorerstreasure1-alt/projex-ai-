{
  "version": 2,
  "name": "projex-ai",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}